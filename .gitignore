# Terraform working directory
.terraform/
**/.terraform/

# Terraform state
*.tfstate
*.tfstate.*

# Terraform lock and crash files
crash.log
crash.*.log

# Ignore local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore tfvars by default (often contains environment-specific values)
*.tfvars
*.tfvars.json

node_modules/